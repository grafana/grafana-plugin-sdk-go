        ],
        "properties": {
            "url": {
                "description": "Server URL",
                "type": "string"
            },
            "jsonData": {
                "type": "object",
                "properties": {
                    "httpMethod": {
                        "description": "HTTP method for requests",
                        "type": "string",
                        "default": "GET"
                    },
                    "enabledFeatures": {
                        "description": "Optional features to enable",
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}
