{
    "schemaVersion": "v1",
    "pluginType": "prometheus",
    "pluginName": "Prometheus",
    "docURL": "https://grafana.com/docs/grafana/latest/datasources/prometheus/",
    "fields": [
        {
            "id": "connection.url",
            "key": "url",
            "label": "URL",
            "description": "Prometheus server URL",
            "valueType": "string",
            "semanticType": "url",
            "target": "root",
            "required": true,
            "ui": {
                "component": "input",
                "placeholder": "http://localhost:9090"
            }
        },
        {
            "id": "auth.basicAuth",
            "key": "basicAuth",
            "label": "Basic Auth",
            "description": "Enable basic authentication",
            "valueType": "boolean",
            "target": "root",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "auth.basicAuthUser",
            "key": "basicAuthUser",
            "label": "User",
            "description": "Basic auth username",
            "valueType": "string",
            "target": "root",
            "dependsOn": "auth.basicAuth == true",
            "requiredWhen": "auth.basicAuth == true",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData.httpMethod",
            "key": "httpMethod",
            "label": "HTTP Method",
            "description": "HTTP method for querying Prometheus",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "POST",
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "GET",
                        "POST"
                    ]
                }
            ],
            "ui": {
                "component": "radio",
                "options": [
                    {
                        "label": "GET",
                        "value": "GET"
                    },
                    {
                        "label": "POST",
                        "value": "POST"
                    }
                ]
            }
        },
        {
            "id": "jsonData.prometheusType",
            "key": "prometheusType",
            "label": "Prometheus Type",
            "description": "Type of Prometheus-compatible backend",
            "valueType": "string",
            "target": "jsonData",
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "Prometheus",
                        "Mimir",
                        "Cortex",
                        "Thanos"
                    ]
                }
            ],
            "ui": {
                "component": "select",
                "options": [
                    {
                        "label": "Prometheus",
                        "value": "Prometheus"
                    },
                    {
                        "label": "Mimir",
                        "value": "Mimir"
                    },
                    {
                        "label": "Cortex",
                        "value": "Cortex"
                    },
                    {
                        "label": "Thanos",
                        "value": "Thanos"
                    }
                ]
            }
        },
        {
            "id": "jsonData.prometheusVersion",
            "key": "prometheusVersion",
            "label": "Version",
            "description": "Prometheus server version",
            "valueType": "string",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData.cacheLevel",
            "key": "cacheLevel",
            "label": "Cache Level",
            "description": "Browser cache level for queries",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "High",
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "Low",
                        "Medium",
                        "High",
                        "None"
                    ]
                }
            ],
            "ui": {
                "component": "select",
                "options": [
                    {
                        "label": "Low",
                        "value": "Low"
                    },
                    {
                        "label": "Medium",
                        "value": "Medium"
                    },
                    {
                        "label": "High",
                        "value": "High"
                    },
                    {
                        "label": "None",
                        "value": "None"
                    }
                ]
            }
        },
        {
            "id": "jsonData.defaultEditor",
            "key": "defaultEditor",
            "label": "Default Editor",
            "description": "Default query editor mode",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "builder",
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "code",
                        "builder"
                    ]
                }
            ],
            "ui": {
                "component": "radio",
                "options": [
                    {
                        "label": "Code",
                        "value": "code"
                    },
                    {
                        "label": "Builder",
                        "value": "builder"
                    }
                ]
            }
        },
        {
            "id": "jsonData.timeInterval",
            "key": "timeInterval",
            "label": "Scrape Interval",
            "description": "Set this to the typical scrape and evaluation interval",
            "valueType": "string",
            "semanticType": "duration",
            "target": "jsonData",
            "defaultValue": "15s",
            "ui": {
                "component": "input",
                "placeholder": "15s"
            }
        },
        {
            "id": "jsonData.queryTimeout",
            "key": "queryTimeout",
            "label": "Query Timeout",
            "description": "Set the Prometheus query timeout",
            "valueType": "string",
            "semanticType": "duration",
            "target": "jsonData",
            "defaultValue": "60s",
            "ui": {
                "component": "input",
                "placeholder": "60s"
            }
        },
        {
            "id": "jsonData.disableMetricsLookup",
            "key": "disableMetricsLookup",
            "label": "Disable Metrics Lookup",
            "description": "Disable metrics name completion and label lookup",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData.incrementalQuerying",
            "key": "incrementalQuerying",
            "label": "Incremental Querying",
            "description": "Enable incremental querying to improve large-range query performance",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData.manageAlerts",
            "key": "manageAlerts",
            "label": "Manage Alerts",
            "description": "Manage alert rules for this datasource",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": true,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData.exemplarTraceIdDestinations",
            "key": "exemplarTraceIdDestinations",
            "label": "Exemplar Trace ID Destinations",
            "description": "Configure exemplar trace ID link destinations",
            "valueType": "array",
            "target": "jsonData",
            "item": {
                "valueType": "object",
                "fields": [
                    {
                        "id": "exemplar.item.name",
                        "key": "name",
                        "description": "Label name containing the trace ID",
                        "valueType": "string",
                        "isItemField": true,
                        "required": true
                    },
                    {
                        "id": "exemplar.item.url",
                        "key": "url",
                        "description": "External URL template",
                        "valueType": "string",
                        "semanticType": "url",
                        "isItemField": true
                    },
                    {
                        "id": "exemplar.item.urlDisplayLabel",
                        "key": "urlDisplayLabel",
                        "description": "Display label for the link",
                        "valueType": "string",
                        "isItemField": true
                    },
                    {
                        "id": "exemplar.item.datasourceUid",
                        "key": "datasourceUid",
                        "description": "Internal datasource UID for trace lookup",
                        "valueType": "string",
                        "semanticType": "datasourceUid",
                        "isItemField": true
                    }
                ]
            }
        },
        {
            "id": "tls.tlsAuth",
            "key": "tlsAuth",
            "label": "TLS Client Auth",
            "description": "Enable TLS client authentication",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "tls.tlsAuthWithCACert",
            "key": "tlsAuthWithCACert",
            "label": "With CA Cert",
            "description": "Enable TLS with CA certificate",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "tls.tlsSkipVerify",
            "key": "tlsSkipVerify",
            "label": "Skip TLS Verify",
            "description": "Skip TLS certificate verification",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "tls.serverName",
            "key": "serverName",
            "label": "Server Name",
            "description": "Server name for SNI and TLS verification",
            "valueType": "string",
            "semanticType": "hostname",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "secure.basicAuthPassword",
            "key": "basicAuthPassword",
            "description": "Basic auth password",
            "valueType": "string",
            "semanticType": "password",
            "target": "secureJsonData",
            "dependsOn": "auth.basicAuth == true"
        },
        {
            "id": "secure.tlsCACert",
            "key": "tlsCACert",
            "description": "TLS CA certificate",
            "valueType": "string",
            "target": "secureJsonData",
            "dependsOn": "tls.tlsAuthWithCACert == true"
        },
        {
            "id": "secure.tlsClientCert",
            "key": "tlsClientCert",
            "description": "TLS client certificate",
            "valueType": "string",
            "target": "secureJsonData",
            "dependsOn": "tls.tlsAuth == true"
        },
        {
            "id": "secure.tlsClientKey",
            "key": "tlsClientKey",
            "description": "TLS client key",
            "valueType": "string",
            "target": "secureJsonData",
            "dependsOn": "tls.tlsAuth == true"
        }
    ],
    "groups": [
        {
            "id": "connection",
            "title": "Connection",
            "fieldRefs": [
                "connection.url"
            ]
        },
        {
            "id": "auth",
            "title": "Authentication",
            "fieldRefs": [
                "auth.basicAuth",
                "auth.basicAuthUser",
                "secure.basicAuthPassword"
            ]
        },
        {
            "id": "query",
            "title": "Query Settings",
            "fieldRefs": [
                "jsonData.httpMethod",
                "jsonData.prometheusType",
                "jsonData.prometheusVersion",
                "jsonData.cacheLevel",
                "jsonData.defaultEditor",
                "jsonData.timeInterval",
                "jsonData.queryTimeout"
            ]
        },
        {
            "id": "features",
            "title": "Features",
            "fieldRefs": [
                "jsonData.disableMetricsLookup",
                "jsonData.incrementalQuerying",
                "jsonData.manageAlerts"
            ]
        },
        {
            "id": "exemplars",
            "title": "Exemplars",
            "fieldRefs": [
                "jsonData.exemplarTraceIdDestinations"
            ]
        },
        {
            "id": "tls",
            "title": "TLS / SSL",
            "fieldRefs": [
                "tls.tlsAuth",
                "tls.tlsAuthWithCACert",
                "tls.tlsSkipVerify",
                "tls.serverName",
                "secure.tlsCACert",
                "secure.tlsClientCert",
                "secure.tlsClientKey"
            ]
        }
    ]
}
