{
    "schemaVersion": "v1",
    "pluginType": "grafana-github-datasource",
    "pluginName": "GitHub",
    "docURL": "https://grafana.com/docs/plugins/grafana-github-datasource/",
    "fields": [
        {
            "id": "connection.url",
            "key": "url",
            "label": "URL",
            "description": "GitHub API URL (only needed for Enterprise Server)",
            "valueType": "string",
            "semanticType": "url",
            "target": "root",
            "ui": {
                "component": "input",
                "placeholder": "https://github.example.com"
            }
        },
        {
            "id": "jsonData.githubPlan",
            "key": "githubPlan",
            "label": "GitHub Plan",
            "description": "GitHub plan type",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "github-basic",
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "github-basic",
                        "github-enterprise-cloud",
                        "github-enterprise-server"
                    ]
                }
            ],
            "ui": {
                "component": "select",
                "options": [
                    {
                        "label": "GitHub",
                        "value": "github-basic"
                    },
                    {
                        "label": "GitHub Enterprise Cloud",
                        "value": "github-enterprise-cloud"
                    },
                    {
                        "label": "GitHub Enterprise Server",
                        "value": "github-enterprise-server"
                    }
                ]
            }
        },
        {
            "id": "jsonData.githubUrl",
            "key": "githubUrl",
            "label": "GitHub Enterprise Server URL",
            "description": "The URL of the GitHub Enterprise Server instance",
            "valueType": "string",
            "semanticType": "url",
            "target": "jsonData",
            "dependsOn": "jsonData.githubPlan == 'github-enterprise-server'",
            "requiredWhen": "jsonData.githubPlan == 'github-enterprise-server'",
            "disabledWhen": "jsonData.githubPlan != 'github-enterprise-server'",
            "ui": {
                "component": "input",
                "placeholder": "https://github.example.com"
            }
        },
        {
            "id": "jsonData.selectedAuthType",
            "key": "selectedAuthType",
            "label": "Authentication",
            "description": "Authentication type",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "personal-access-token",
            "validations": [
                {
                    "type": "allowedValues",
                    "values": [
                        "personal-access-token",
                        "github-app"
                    ]
                }
            ],
            "ui": {
                "component": "select",
                "options": [
                    {
                        "label": "Personal Access Token",
                        "value": "personal-access-token"
                    },
                    {
                        "label": "GitHub App",
                        "value": "github-app"
                    }
                ]
            }
        },
        {
            "id": "jsonData.appId",
            "key": "appId",
            "label": "App ID",
            "description": "The GitHub App ID",
            "valueType": "string",
            "target": "jsonData",
            "dependsOn": "jsonData.selectedAuthType == 'github-app'",
            "requiredWhen": "jsonData.selectedAuthType == 'github-app'",
            "disabledWhen": "jsonData.selectedAuthType != 'github-app'",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData.installationId",
            "key": "installationId",
            "label": "Installation ID",
            "description": "The GitHub App installation ID",
            "valueType": "string",
            "target": "jsonData",
            "dependsOn": "jsonData.selectedAuthType == 'github-app'",
            "requiredWhen": "jsonData.selectedAuthType == 'github-app'",
            "disabledWhen": "jsonData.selectedAuthType != 'github-app'",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "secure.accessToken",
            "key": "accessToken",
            "label": "Personal Access Token",
            "description": "Personal access token for GitHub API authentication",
            "valueType": "string",
            "semanticType": "token",
            "target": "secureJsonData",
            "dependsOn": "jsonData.selectedAuthType == 'personal-access-token'",
            "requiredWhen": "jsonData.selectedAuthType == 'personal-access-token'"
        },
        {
            "id": "secure.privateKey",
            "key": "privateKey",
            "label": "Private Key",
            "description": "Private key for GitHub App authentication (PEM format)",
            "valueType": "string",
            "target": "secureJsonData",
            "dependsOn": "jsonData.selectedAuthType == 'github-app'",
            "requiredWhen": "jsonData.selectedAuthType == 'github-app'",
            "ui": {
                "component": "textarea"
            }
        }
    ],
    "groups": [
        {
            "id": "connection",
            "title": "Connection",
            "fieldRefs": [
                "connection.url",
                "jsonData.githubPlan",
                "jsonData.githubUrl"
            ]
        },
        {
            "id": "auth",
            "title": "Authentication",
            "fieldRefs": [
                "jsonData.selectedAuthType",
                "jsonData.appId",
                "jsonData.installationId",
                "secure.accessToken",
                "secure.privateKey"
            ]
        }
    ]
}
