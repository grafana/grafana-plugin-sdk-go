{
    "schemaVersion": "v1",
    "pluginType": "loki",
    "pluginName": "Loki",
    "docURL": "https://grafana.com/docs/grafana/latest/datasources/loki/",
    "fields": [
        {
            "id": "connection.url",
            "key": "url",
            "label": "URL",
            "description": "Loki server URL",
            "valueType": "string",
            "semanticType": "url",
            "target": "root",
            "required": true,
            "ui": {
                "component": "input",
                "placeholder": "http://localhost:3100"
            }
        },
        {
            "id": "auth.basicAuth",
            "key": "basicAuth",
            "label": "Basic Auth",
            "description": "Enable basic authentication",
            "valueType": "boolean",
            "target": "root",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "auth.basicAuthUser",
            "key": "basicAuthUser",
            "label": "User",
            "description": "Basic auth username",
            "valueType": "string",
            "target": "root",
            "dependsOn": "auth.basicAuth == true",
            "requiredWhen": "auth.basicAuth == true",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData.maxLines",
            "key": "maxLines",
            "label": "Maximum Lines",
            "description": "Maximum number of lines returned per query",
            "valueType": "string",
            "target": "jsonData",
            "defaultValue": "1000",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData.manageAlerts",
            "key": "manageAlerts",
            "label": "Manage Alerts",
            "description": "Manage alert rules for this datasource",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": true,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "jsonData.timeout",
            "key": "timeout",
            "label": "Timeout",
            "description": "Query timeout in seconds",
            "valueType": "number",
            "target": "jsonData",
            "validations": [
                {
                    "type": "range",
                    "min": 1,
                    "max": 600
                }
            ],
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "jsonData.derivedFields",
            "key": "derivedFields",
            "label": "Derived Fields",
            "description": "Derived fields create links from log lines to other datasources",
            "valueType": "array",
            "target": "jsonData",
            "item": {
                "valueType": "object",
                "fields": [
                    {
                        "id": "derived.item.matcherRegex",
                        "key": "matcherRegex",
                        "description": "Regex to match and extract value from log line",
                        "valueType": "string",
                        "isItemField": true,
                        "required": true,
                        "validations": [
                            {
                                "type": "length",
                                "min": 1,
                                "max": 500
                            }
                        ]
                    },
                    {
                        "id": "derived.item.name",
                        "key": "name",
                        "description": "Display name for the derived field",
                        "valueType": "string",
                        "isItemField": true,
                        "required": true
                    },
                    {
                        "id": "derived.item.url",
                        "key": "url",
                        "description": "External link URL template",
                        "valueType": "string",
                        "semanticType": "url",
                        "isItemField": true
                    },
                    {
                        "id": "derived.item.urlDisplayLabel",
                        "key": "urlDisplayLabel",
                        "description": "Display label for the link",
                        "valueType": "string",
                        "isItemField": true
                    },
                    {
                        "id": "derived.item.datasourceUid",
                        "key": "datasourceUid",
                        "description": "Internal datasource for trace lookup",
                        "valueType": "string",
                        "semanticType": "datasourceUid",
                        "isItemField": true
                    },
                    {
                        "id": "derived.item.matcherType",
                        "key": "matcherType",
                        "description": "Type of matcher",
                        "valueType": "string",
                        "isItemField": true,
                        "validations": [
                            {
                                "type": "allowedValues",
                                "values": [
                                    "label",
                                    "regex"
                                ]
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": "tls.tlsAuth",
            "key": "tlsAuth",
            "description": "Enable TLS client authentication",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "tls.tlsAuthWithCACert",
            "key": "tlsAuthWithCACert",
            "description": "Enable TLS with CA certificate",
            "valueType": "boolean",
            "target": "jsonData",
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "tls.tlsSkipVerify",
            "key": "tlsSkipVerify",
            "description": "Skip TLS certificate verification",
            "valueType": "boolean",
            "target": "jsonData",
            "defaultValue": false,
            "ui": {
                "component": "switch"
            }
        },
        {
            "id": "tls.serverName",
            "key": "serverName",
            "description": "Server name for TLS verification",
            "valueType": "string",
            "semanticType": "hostname",
            "target": "jsonData",
            "ui": {
                "component": "input"
            }
        },
        {
            "id": "secure.basicAuthPassword",
            "key": "basicAuthPassword",
            "description": "Basic auth password",
            "valueType": "string",
            "semanticType": "password",
            "target": "secureJsonData",
            "dependsOn": "auth.basicAuth == true"
        },
        {
            "id": "secure.tlsCACert",
            "key": "tlsCACert",
            "description": "TLS CA certificate",
            "valueType": "string",
            "target": "secureJsonData",
            "dependsOn": "tls.tlsAuthWithCACert == true"
        },
        {
            "id": "secure.tlsClientCert",
            "key": "tlsClientCert",
            "description": "TLS client certificate",
            "valueType": "string",
            "target": "secureJsonData",
            "dependsOn": "tls.tlsAuth == true"
        },
        {
            "id": "secure.tlsClientKey",
            "key": "tlsClientKey",
            "description": "TLS client key",
            "valueType": "string",
            "target": "secureJsonData",
            "dependsOn": "tls.tlsAuth == true"
        }
    ],
    "groups": [
        {
            "id": "connection",
            "title": "Connection",
            "fieldRefs": [
                "connection.url"
            ]
        },
        {
            "id": "auth",
            "title": "Authentication",
            "fieldRefs": [
                "auth.basicAuth",
                "auth.basicAuthUser",
                "secure.basicAuthPassword"
            ]
        },
        {
            "id": "query",
            "title": "Query Settings",
            "fieldRefs": [
                "jsonData.maxLines",
                "jsonData.timeout",
                "jsonData.manageAlerts"
            ]
        },
        {
            "id": "derived",
            "title": "Derived Fields",
            "fieldRefs": [
                "jsonData.derivedFields"
            ]
        },
        {
            "id": "tls",
            "title": "TLS / SSL",
            "fieldRefs": [
                "tls.tlsAuth",
                "tls.tlsAuthWithCACert",
                "tls.tlsSkipVerify",
                "tls.serverName",
                "secure.tlsCACert",
                "secure.tlsClientCert",
                "secure.tlsClientKey"
            ]
        }
    ]
}
